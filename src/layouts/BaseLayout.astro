---

import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og-default.jpg',
  schema
} = Astro.props;

const canonicalURL = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_ES" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "PetStore",
    "name": "Centro Puppy Home",
    "url": "https://centropuppyhome.com",
    "telephone": "+34958269455",
    "email": "info@centropuppyhome.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Granada",
      "addressRegion": "Andalucía",
      "addressCountry": "ES"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "37.1773",
      "longitude": "-3.5986"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "10:00",
        "closes": "19:00"
      }
    ],
    "sameAs": [
      "https://www.instagram.com/centropuppyhome",
      "https://www.facebook.com/centropuppyhome"
    ]
  }
  </script>

  <style is:global>
    .site-header {
      background: #fff9f4;
      border-bottom: 1px solid #e8d5c4;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .logo-container {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      color: #2c1810;
      font-weight: 700;
      text-decoration: none;
      position: relative;
      z-index: 300;
    }
    .logo span { color: #d4a853; }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 1.5rem;
      align-items: center;
      margin: 0;
      padding: 0;
    }
    .nav-links a {
      font-size: 0.9rem;
      font-weight: 500;
      color: #4a3428;
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #6b3a2a; }
    .nav-links a.active {
      color: #6b3a2a;
      font-weight: 700;
      border-bottom: 2px solid #d4a853;
      padding-bottom: 2px;
    }
    .btn-contactar {
      background: #6b3a2a !important;
      color: white !important;
      padding: 0.5rem 1.2rem !important;
      border-radius: 6px !important;
      font-weight: 600 !important;
      font-size: 0.85rem !important;
      transition: background 0.2s !important;
      border-bottom: none !important;
    }
    .btn-contactar:hover {
      background: #2c1810 !important;
      color: white !important;
    }

.has-dropdown { position: relative; }

.has-dropdown > a {
  padding-bottom: 1rem;
  margin-bottom: -1rem;
}

.dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 0.25rem);
  left: 50%;
  transform: translateX(-50%);
  background: white;
  border: 1px solid #e8d5c4;
  border-radius: 12px;
  padding: 0.75rem 0 0.5rem;
  min-width: 220px;
  box-shadow: 0 8px 32px rgba(44,24,16,0.12);
  z-index: 500;
  list-style: none;
  margin: 0;
}

.dropdown::before {
  content: '';
  position: absolute;
  top: -1rem;
  left: 0;
  right: 0;
  height: 1rem;
}

.dropdown li a {
  display: block;
  padding: 0.6rem 1.25rem;
  font-size: 0.9rem;
  color: #4a3428;
  white-space: nowrap;
  border-left: 3px solid transparent;
  border-bottom: none !important;
  transition: all 0.15s;
}

.dropdown li:first-child a {
  font-weight: 600;
  color: #6b3a2a;
  border-bottom: 1px solid #e8d5c4 !important;
  margin-bottom: 0.25rem;
}

.dropdown li a:hover {
  background: #fdf8f2;
  color: #6b3a2a;
  border-left-color: #d4a853;
}

.has-dropdown:hover .dropdown,
.has-dropdown:focus-within .dropdown { display: block; }

    .nav-toggle {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      z-index: 300;
      position: relative;
    }
    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: #2c1810;
      border-radius: 2px;
      transition: all 0.3s ease;
      transform-origin: center;
    }
    .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .nav-mobile {
      display: none !important;
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100dvh;
      background: #fff9f4;
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.1rem;
      padding: 2rem;
      text-align: center;
      overflow-y: auto;
    }
    .nav-mobile.open { display: flex !important; }
    .nav-mobile a {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      color: #2c1810;
      text-decoration: none;
      font-weight: 700;
      line-height: 1;
      transition: color 0.2s;
    }
    .nav-mobile a:hover,
    .nav-mobile a.active { color: #d4a853; }
    .btn-mobile-contactar {
      font-family: 'DM Sans', system-ui, sans-serif !important;
      font-size: 1rem !important;
      margin-top: 0.5rem;
      background: #d4a853;
      color: #2c1810 !important;
      padding: 0.85rem 2.5rem;
      border-radius: 6px;
      font-weight: 700 !important;
    }

    .footer-col a.active { color: #d4a853 !important; }

    #scrollTop {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      width: 48px;
      height: 48px;
      background: #6b3a2a;
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 1.4rem;
      cursor: pointer;
      z-index: 999;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(44,24,16,0.3);
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.3s, transform 0.3s, background 0.2s;
      pointer-events: none;
    }
    #scrollTop.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    #scrollTop:hover { background: #d4a853; color: #2c1810; }

    @media (max-width: 900px) {
      .nav-links { display: none !important; }
      .nav-toggle { display: flex; }
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="header-inner">
      <div class="logo-container">
        <a href="/" class="logo-img">
          <img src="/logo.png" alt="Centro Puppy Home" height="48" width="48" />
        </a>
        <a href="/" class="logo">Puppy<span>Home</span></a>
      </div>
      <nav aria-label="Navegación principal">
        <ul class="nav-links">
          <li><a href="/quienes-somos/">Quiénes Somos</a></li>
          <li class="has-dropdown">
            <a href="/cachorros-granada/">Nuestras Razas ▾</a>
            <ul class="dropdown">
              <li><a href="/cachorros-granada/">Ver todas las razas</a></li>
              <li><a href="/chihuahua-granada/">Chihuahua</a></li>
              <li><a href="/pomerania-granada/">Lulú de Pomerania</a></li>
              <li><a href="/yorkshire-granada/">Yorkshire Terrier</a></li>
              <li><a href="/bichon-maltes-granada/">Bichón Maltés</a></li>
              <li><a href="/caniche-toy-granada/">Caniche Toy</a></li>
            </ul>
          </li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="tel:+34958269455">958 269 455</a></li>
          <li><a href="/#contacto" class="btn-contactar">Contactar</a></li>
        </ul>
      </nav>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

<nav class="nav-mobile" id="navMobile" aria-label="Menú móvil" aria-hidden="true">
    <button class="nav-mobile-close" id="navClose" aria-label="Cerrar menú">✕</button>
    <a href="/" class="menu-link">Inicio</a>
    <a href="/quienes-somos/" class="menu-link">Quiénes Somos</a>
    <a href="/cachorros-granada/" class="menu-link">Todas las razas</a>
    <a href="/chihuahua-granada/" class="menu-link">Chihuahua</a>
    <a href="/pomerania-granada/" class="menu-link">Pomerania</a>
    <a href="/yorkshire-granada/" class="menu-link">Yorkshire</a>
    <a href="/bichon-maltes-granada/" class="menu-link">Bichón Maltés</a>
    <a href="/caniche-toy-granada/" class="menu-link">Caniche Toy</a>
    <a href="/blog/" class="menu-link">Blog</a>
    <a href="/#contacto" class="btn-mobile-contactar menu-link">Contactar</a>
  </nav>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo" style="color:white;">Puppy<span style="color:#d4a853">Home</span></a>
          <p>Centro canino de cría responsable en Granada. Más de 15 años llevando felicidad a los hogares con cachorros toy criados en semilibertad.</p>
          <p style="margin-top:0.75rem;font-size:0.85rem;color:rgba(255,255,255,0.4);">Núcleo Zoológico: 175GR00211</p>
          <div style="margin-top:1rem;">
            <a href="tel:+34958269455" style="color:#d4a853;font-weight:600;">📞 958 269 455</a>
          </div>
          <div style="margin-top:0.5rem;">
            <a href="mailto:info@centropuppyhome.com" style="color:rgba(255,255,255,0.6);font-size:0.9rem;">info@centropuppyhome.com</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Nuestras Razas</h4>
          <ul>
            <li><a href="/chihuahua-granada/">Chihuahua en Granada</a></li>
            <li><a href="/pomerania-granada/">Lulú de Pomerania</a></li>
            <li><a href="/yorkshire-granada/">Yorkshire Terrier</a></li>
            <li><a href="/bichon-maltes-granada/">Bichón Maltés</a></li>
            <li><a href="/caniche-toy-granada/">Caniche Toy</a></li>
            <li><a href="/cachorros-granada/">Ver todas</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Centro</h4>
          <ul>
            <li><a href="/quienes-somos/">Quiénes Somos</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/#contacto">Contacto</a></li>
            <li><a href="/aviso-legal/">Aviso Legal</a></li>
            <li><a href="/politica-privacidad/">Privacidad</a></li>
          </ul>
          <h4 style="margin-top:1.5rem;">Horario</h4>
          <p style="color:rgba(255,255,255,0.6);font-size:0.85rem;margin:0;">Lun–Vie: 10:00–19:00<br/>Fuera de horario: email</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Centro Puppy Home · Granada, Andalucía · Todos los derechos reservados</p>
      </div>
    </div>
  </footer>

  <button id="scrollTop" aria-label="Volver arriba">↑</button>

  <script is:inline>
    (function () {
      const toggle = document.getElementById('navToggle');
      const menu   = document.getElementById('navMobile');
      if (toggle && menu) {
        function openMenu() {
          menu.classList.add('open');
          toggle.classList.add('open');
          toggle.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }
        function closeMenu() {
          menu.classList.remove('open');
          toggle.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }

        const closeBtn = document.getElementById('navClose');
        if (closeBtn) {
          closeBtn.addEventListener('click', closeMenu);
        }


        toggle.addEventListener('click', function () {
          menu.classList.contains('open') ? closeMenu() : openMenu();
        });
        document.querySelectorAll('.menu-link').forEach(function (link) {
          link.addEventListener('click', closeMenu);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeMenu();
        });
      }

      const btn = document.getElementById('scrollTop');
      if (btn) {
        window.addEventListener('scroll', function () {
          btn.classList.toggle('visible', window.scrollY > 400);
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      const path = window.location.pathname;
      document.querySelectorAll('.nav-links a, .nav-mobile a, .footer-col a').forEach(function (link) {
        const href = link.getAttribute('href');
        if (!href) return;
        if (href === '/' && path === '/') { link.classList.add('active'); return; }
        if (href !== '/' && path.startsWith(href)) link.classList.add('active');
      });
    })();
  </script>

</body>
</html>
